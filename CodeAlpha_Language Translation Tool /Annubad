];

const LANG_MAP = {};
LANGUAGES.forEach(l => { LANG_MAP[l.code] = l.name.replace(/[\p{Emoji_Presentation}\p{Extended_Pictographic}]/gu,'').trim(); });

/* ── DOM refs ── */
const srcLangEl     = document.getElementById('src-lang');
const tgtLangEl     = document.getElementById('tgt-lang');
const tgtLangName   = document.getElementById('tgt-lang-name');
const inputText     = document.getElementById('input-text');
const outputEl      = document.getElementById('output-text');
const charCountEl   = document.getElementById('char-count');
const transBtn      = document.getElementById('translate-btn');
const btnLabel      = document.getElementById('btn-label');
const btnIcon       = document.getElementById('btn-icon');
const swapBtn       = document.getElementById('swap-btn');
const detectedBadge = document.getElementById('detected-badge');
const detectedName  = document.getElementById('detected-lang-name');
const errorBanner   = document.getElementById('error-banner');
const errorTitle    = document.getElementById('error-title');
const errorMsg      = document.getElementById('error-msg');
const statsGroup    = document.getElementById('stats-group');
const themeBtn      = document.getElementById('theme-btn');
const themeLabel    = document.getElementById('theme-label');
const toastEl       = document.getElementById('toast');
const chips         = document.querySelectorAll('.chip');

/* FROM-pane buttons */
const clearBtn      = document.getElementById('clear-btn');
const copyInputBtn  = document.getElementById('copy-input-btn');
const ttsInputBtn   = document.getElementById('tts-input-btn');

/* TO-pane buttons */
const copyOutputBtn = document.getElementById('copy-output-btn');
const ttsOutputBtn  = document.getElementById('tts-output-btn');

/* ── Populate selects ── */
(function() {
  LANGUAGES.forEach(l => {
    srcLangEl.add(new Option(l.name, l.code));
    if (l.code !== 'auto') tgtLangEl.add(new Option(l.name, l.code));
  });
  srcLangEl.value = 'auto';
  tgtLangEl.value = 'en';
  updateTgtName();
})();

function updateTgtName() {
  const n = LANG_MAP[tgtLangEl.value] || '';
  tgtLangName.textContent = n;
}
tgtLangEl.addEventListener('change', () => { updateTgtName(); chips.forEach(c=>c.classList.remove('active')); });

/* ── Theme ── */
let isDark = false;
themeBtn.addEventListener('click', () => {
  isDark = !isDark;
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
  themeLabel.textContent = isDark ? 'Dark' : 'Light';
});

/* ── Char counter ── */
inputText.addEventListener('input', () => {
  const len = inputText.value.length;
  charCountEl.textContent = `${len} / 5000`;
  charCountEl.className = 'char-count' + (len > 4500 ? ' over' : len > 3500 ? ' warn' : '');
  hideError();
});

/* ── Quick chips ── */
chips.forEach(chip => {
  chip.addEventListener('click', () => {
    tgtLangEl.value = chip.dataset.lang;
    chips.forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    updateTgtName();
  });
});

/* ── Swap ── */
swapBtn.addEventListener('click', () => {
  const srcVal = srcLangEl.value;
  const tgtVal = tgtLangEl.value;
  srcLangEl.value = tgtVal;
  tgtLangEl.value = srcVal === 'auto' ? 'en' : srcVal;
  updateTgtName();
  if (lastTranslation) {
    inputText.value = lastTranslation;
    inputText.dispatchEvent(new Event('input'));
    resetOutput();
  }
});

/* ── State ── */
let lastTranslation = '';

/* ── UI helpers ── */
function showLoading() {
  outputEl.innerHTML = `
    <div class="shimmer"></div>
    <div class="shimmer"></div>
    <div class="shimmer"></div>`;
  detectedBadge.classList.remove('show');
  statsGroup.style.display = 'none';
}

function showOutput(text, matchScore, detLang) {
  lastTranslation = text;
  outputEl.textContent = text;
  copyOutputBtn.disabled = false;
  ttsOutputBtn.disabled = false;

  if (detLang && srcLangEl.value === 'auto') {
    const name = LANG_MAP[detLang] || detLang;
    detectedName.textContent = 'Detected: ' + name;
    detectedBadge.classList.add('show');
  } else {
    detectedBadge.classList.remove('show');
  }

  const words = text.trim().split(/\s+/).filter(Boolean).length;
  document.getElementById('stat-words').textContent = words;
  document.getElementById('stat-chars').textContent = text.length;
  statsGroup.style.display = 'flex';
}

function resetOutput() {
  outputEl.innerHTML = '<span class="output-placeholder">Translation appears here…</span>';
  copyOutputBtn.disabled = true;
  ttsOutputBtn.disabled = true;
  lastTranslation = '';
  detectedBadge.classList.remove('show');
  statsGroup.style.display = 'none';
}

function showError(title, msg) {
  errorBanner.classList.add('show');
  errorTitle.textContent = title;
  errorMsg.textContent = msg ? ' — ' + msg : '';
}
function hideError() { errorBanner.classList.remove('show'); }

function showToast(msg) {
  toastEl.textContent = msg;
  toastEl.classList.add('show');
  setTimeout(() => toastEl.classList.remove('show'), 2800);
}

function setLoading(on) {
  transBtn.disabled = on;
  if (on) {
    btnIcon.innerHTML = '<span class="spinner"></span>';
    btnLabel.textContent = 'Translating…';
  } else {
    btnIcon.textContent = '✦';
    btnLabel.textContent = 'Translate';
  }
}

function decodeHtml(html) {
  const t = document.createElement('textarea');
  t.innerHTML = html; return t.value;
}

/* ═══════════════════════════════════════════
   TRANSLATE — MyMemory API
   GET https://api.mymemory.translated.net/get
   ?q=<text>&langpair=<src>|<tgt>
═══════════════════════════════════════════ */
async function doTranslate() {
  const text = inputText.value.trim();
  if (!text) { showToast('⚠ Please enter some text first.'); return; }
  const srcCode = srcLangEl.value;
  const tgtCode = tgtLangEl.value;
  if (srcCode !== 'auto' && srcCode === tgtCode) {
    showToast('⚠ Source and target language are the same.'); return;
  }

  hideError(); setLoading(true); showLoading();

  const langpair = (srcCode === 'auto' ? 'autodetect' : srcCode) + '|' + tgtCode;
  const url = new URL('https://api.mymemory.translated.net/get');
  url.searchParams.set('q', text);
  url.searchParams.set('langpair', langpair);
  // Tip: add ?de=your@email.com for 10 000 chars/day instead of 500

  const t0 = performance.now();
  try {
    const resp = await fetch(url.toString());
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);

    const data = await resp.json();
    document.getElementById('stat-speed').textContent = ((performance.now()-t0)/1000).toFixed(2)+'s';

    const code = data.responseStatus;
    if (code !== 200 && code !== '200') {
      if (code===429||code==='429') throw new Error('Daily limit reached. Add ?de=your@email.com for more.');
      if (code===403||code==='403') throw new Error(`Pair "${langpair}" not supported.`);
      throw new Error(data.responseDetails || `API error (${code})`);
    }

    let translated = data.responseData?.translatedText || '';
    if (!translated || translated.toLowerCase().includes('mymemory warning'))
      throw new Error('No translation returned. Try shorter text or different languages.');

    translated = decodeHtml(translated);
    const matchScore = parseFloat(data.responseData?.match) || null;
    const detLang = srcCode === 'auto'
      ? (data.detectedLanguage?.language || data.matches?.[0]?.source || '')
      : '';

    showOutput(translated, matchScore, detLang);

  } catch(e) {
    resetOutput();
    if (e.name==='TypeError' && e.message.includes('fetch'))
      showError('Network Error','Check your internet connection.');
    else
      showError('Translation Failed', e.message);
  } finally {
    setLoading(false);
  }
}

/* ── Events ── */
transBtn.addEventListener('click', doTranslate);
inputText.addEventListener('keydown', e => {
  if ((e.ctrlKey||e.metaKey) && e.key==='Enter') { e.preventDefault(); doTranslate(); }
});

/* FROM pane — Clear */
clearBtn.addEventListener('click', () => {
  inputText.value = '';
  charCountEl.textContent = '0 / 5000';
  charCountEl.className = 'char-count';
  resetOutput(); hideError(); inputText.focus();
});

/* FROM pane — Copy input */
copyInputBtn.addEventListener('click', async () => {
  const t = inputText.value; if (!t) return;
  try {
    await navigator.clipboard.writeText(t);
    copyInputBtn.classList.add('success');
    copyInputBtn.textContent = '✓ Copied!';
    showToast('✓ Input text copied!');
    setTimeout(() => { copyInputBtn.classList.remove('success'); copyInputBtn.innerHTML = '⎘ Copy'; }, 2000);
  } catch { showToast('⚠ Clipboard access denied.'); }
});

/* ═══════════════════════════════════════════════════════
   SPEAK ENGINE
   Strategy:
   1. Try Web Speech API first (works for English, Spanish, French…)
   2. If the browser has NO voice for that language code, fall back
      to MyMemory TTS API which supports Bengali, Hindi, Arabic, etc.
      GET https://api.mymemory.translated.net/get
          ?q=<text>&langpair=<lang>|<lang>&of=t
      The "of=t" flag returns only the tts audio URL in responseData.
   We also keep a hardcoded set of language codes that almost never
   have a system voice so we skip straight to the API for them.
═══════════════════════════════════════════════════════ */

/* Languages that browsers almost never have voices for — go straight to API TTS */
const NO_BROWSER_VOICE = new Set([
  'bn','hi','ur','pa','gu','mr','ne','ta','te','kn','ml',
  'si','my','km','lo','am','sw','yo','ig','ha','zu',
  'ar','fa','he','ps','ug','kk','uz','hy','ka','az',
  'mn','bo','ky','tg','tk','tt','cv','ba','sah',
  'th','vi','id','ms','tl','jv','su',
  'zh-CN','zh-TW','ja','ko',
]);

let currentAudio = null; // track MyMemory audio so we can stop it

async function speakText(text, langCode, btn) {
  if (!text) { showToast('⚠ Nothing to speak.'); return; }

  /* Stop any currently playing audio */
  if (currentAudio) { currentAudio.pause(); currentAudio = null; }
  if (window.speechSynthesis) window.speechSynthesis.cancel();

  const originalHtml = btn.innerHTML;
  btn.innerHTML = '⏹ Stop';
  btn.classList.add('success');

  /* Check if we should skip browser TTS */
  const useApi = NO_BROWSER_VOICE.has(langCode) || !hasBrowserVoice(langCode);

  if (useApi) {
    await speakViaApi(text, langCode, btn, originalHtml);
  } else {
    speakViaBrowser(text, langCode, btn, originalHtml);
  }
}

/* Check if browser has at least one voice for this lang prefix */
function hasBrowserVoice(langCode) {
  if (!window.speechSynthesis) return false;
  const voices = window.speechSynthesis.getVoices();
  const prefix = langCode.split('-')[0].toLowerCase();
  return voices.some(v => v.lang.toLowerCase().startsWith(prefix));
}

/* Browser TTS — for well-supported languages */
function speakViaBrowser(text, langCode, btn, originalHtml) {
  const utt = new SpeechSynthesisUtterance(text);
  utt.lang = langCode.replace('-','_');
  utt.rate = 0.93;
  utt.onend = () => resetSpeakBtn(btn, originalHtml);
  utt.onerror = () => resetSpeakBtn(btn, originalHtml);
  window.speechSynthesis.speak(utt);
  showToast('🔊 Speaking…');
}

/* MyMemory TTS API — for Bengali, Hindi, Arabic and other languages
   without browser voices. Fetches an audio stream URL and plays it. */
async function speakViaApi(text, langCode, btn, originalHtml) {
  /* MyMemory TTS: encode the text and request audio */
  /* The API supports a direct audio endpoint via Google TTS proxy */
  /* Format: https://api.mymemory.translated.net/get?q=TEXT&langpair=LANG|LANG&of=t */

  /* We use Google Translate's public TTS endpoint which MyMemory also uses.
     This is the same engine powering Google Translate's speaker button. */
  const MAX_CHARS = 200; // TTS API limit per request
  const chunks = splitIntoChunks(text, MAX_CHARS);

  showToast('🔊 Loading audio…');

  try {
    await playChunksSequentially(chunks, langCode, btn, originalHtml);
  } catch(e) {
    resetSpeakBtn(btn, originalHtml);
    showToast('⚠ Audio playback failed. Try a different browser.');
  }
}

/* Split text into chunks of max N characters at word boundaries */
function splitIntoChunks(text, maxLen) {
  const chunks = [];
  const words = text.split(' ');
  let current = '';
  for (const word of words) {
    if ((current + ' ' + word).trim().length > maxLen) {
      if (current) chunks.push(current.trim());
      current = word;
    } else {
      current = (current + ' ' + word).trim();
    }
  }
  if (current) chunks.push(current.trim());
  return chunks.length ? chunks : [text.slice(0, maxLen)];
}

/* Play each chunk one after another */
async function playChunksSequentially(chunks, langCode, btn, originalHtml) {
  for (let i = 0; i < chunks.length; i++) {
    const chunk = chunks[i];
    /* Google Translate TTS — public endpoint, same one used in Google Translate UI */
    const ttsUrl = `https://translate.googleapis.com/translate_tts?ie=UTF-8&q=${encodeURIComponent(chunk)}&tl=${encodeURIComponent(langCode)}&client=gtx&ttsspeed=0.9`;

    await new Promise((resolve, reject) => {
      const audio = new Audio(ttsUrl);
      currentAudio = audio;
      audio.oncanplaythrough = () => {
        if (i === 0) showToast('🔊 Speaking…');
        audio.play().catch(reject);
      };
      audio.onended = () => { currentAudio = null; resolve(); };
      audio.onerror = () => {
        /* If Google TTS blocked, try MyMemory fallback */
        currentAudio = null;
        speakViaMyMemoryFallback(chunk, langCode).then(resolve).catch(reject);
      };
    });

    /* If stop was pressed mid-chunk, abort */
    if (!currentAudio && i < chunks.length - 1 && btn.innerHTML.includes('Stop') === false) break;
  }
  resetSpeakBtn(btn, originalHtml);
}

/* Last-resort: MyMemory's own TTS (returns audio blob) */
async function speakViaMyMemoryFallback(text, langCode) {
  const url = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(text)}&langpair=${langCode}|${langCode}&of=t`;
  const resp = await fetch(url);
  const data = await resp.json();
  const audioUrl = data.responseData?.translatedText;
  if (audioUrl && audioUrl.startsWith('http')) {
    await new Promise((resolve) => {
      const audio = new Audio(audioUrl);
      currentAudio = audio;
      audio.onended = () => { currentAudio = null; resolve(); };
      audio.onerror = resolve; // silently fail
      audio.play().catch(resolve);
    });
  }
}

function resetSpeakBtn(btn, originalHtml) {
  btn.innerHTML = originalHtml;
  btn.classList.remove('success');
  currentAudio = null;
}

/* ── FROM pane — Speak input ── */
ttsInputBtn.addEventListener('click', () => {
  /* If already speaking, stop */
  if (ttsInputBtn.innerHTML.includes('Stop')) {
    if (currentAudio) { currentAudio.pause(); currentAudio = null; }
    if (window.speechSynthesis) window.speechSynthesis.cancel();
    resetSpeakBtn(ttsInputBtn, '🔊 Speak');
    return;
  }
  const t = inputText.value.trim();
  const lang = srcLangEl.value === 'auto' ? 'en' : srcLangEl.value;
  speakText(t, lang, ttsInputBtn);
});

/* TO pane — Copy output */
copyOutputBtn.addEventListener('click', async () => {
  if (!lastTranslation) return;
  try {
    await navigator.clipboard.writeText(lastTranslation);
    copyOutputBtn.classList.add('success');
    copyOutputBtn.textContent = '✓ Copied!';
    showToast('✓ Translation copied!');
    setTimeout(() => { copyOutputBtn.classList.remove('success'); copyOutputBtn.innerHTML = '⎘ Copy'; }, 2000);
  } catch { showToast('⚠ Clipboard access denied.'); }
});

/* ── TO pane — Speak output ── */
ttsOutputBtn.addEventListener('click', () => {
  /* If already speaking, stop */
  if (ttsOutputBtn.innerHTML.includes('Stop')) {
    if (currentAudio) { currentAudio.pause(); currentAudio = null; }
    if (window.speechSynthesis) window.speechSynthesis.cancel();
    resetSpeakBtn(ttsOutputBtn, '🔊 Speak');
    return;
  }
  speakText(lastTranslation, tgtLangEl.value, ttsOutputBtn);
});
